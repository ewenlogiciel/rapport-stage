---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Rapport de stage BUT MMI — Développement Web' } = Astro.props;

const nav = [
  { href: '/', label: 'Accueil' },
  { href: '/entreprise', label: 'Entreprise' },
  { href: '/missions', label: 'Missions' },
  { href: '/competences', label: 'Compétences' },
  { href: '/bilan', label: 'Bilan' },
];

const current = Astro.url.pathname;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="view-transition" content="same-origin" />
    <title>{title} — Rapport de Stage</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body class="grain min-h-screen font-sans antialiased">

    <!-- Barre de navigation -->
    <header class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 backdrop-blur-md bg-canvas/80">
      <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="text-sm font-semibold text-white tracking-wide">
          Rapport de Stage
        </a>
        <ul class="hidden md:flex items-center gap-6">
          {nav.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class={`text-sm transition-colors ${
                  current === href
                    ? 'text-accent-light font-medium'
                    : 'text-neutral-400 hover:text-white'
                }`}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Menu burger mobile -->
        <button id="menu-toggle" class="md:hidden text-neutral-400 hover:text-white" aria-label="Menu">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </nav>

      <!-- Menu mobile déroulant -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-white/5">
        <ul class="px-6 py-4 space-y-3">
          {nav.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class={`block text-sm py-1 transition-colors ${
                  current === href
                    ? 'text-accent-light font-medium'
                    : 'text-neutral-400 hover:text-white'
                }`}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </header>

    <slot />

    <footer class="border-t border-white/5 mt-24 py-8">
      <div class="max-w-5xl mx-auto px-6 flex items-center justify-between text-xs text-neutral-600">
        <span>BUT MMI — Développement Web · [Année]</span>
        <span>[Prénom Nom]</span>
      </div>
    </footer>

    <script>
      // Menu mobile
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));

      // Reveal au scroll
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => e.isIntersecting && e.target.classList.add('visible')),
        { threshold: 0.1 }
      );
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
