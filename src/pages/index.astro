      { n: '02', title: 'Lint & Test', desc: "Analyse de la syntaxe du code pour assurer sa conformité aux standards professionnels et exécution des tests unitaires pour valider la logique métier." },
      { n: '03', title: 'Security Audit', desc: "Scan automatisé des dépendances PHP pour détecter si une bibliothèque externe utilisée par le projet comporte une vulnérabilité connue." },
      { n: '04', title: 'SAST (Static Application Security Testing)', desc: "Analyse statique automatique du code source pour identifier d'éventuelles failles de sécurité directement dans notre propre code (comme des risques d'injections SQL) à l'aide des outils PHPStan et enlightn/security-checker." },
      { n: '05', title: 'Build & Deploy', desc: "Si et seulement si toutes les étapes précédentes réussissent et que le score de sécurité est validé par la pipeline, le projet est automatiquement packagé et déployé via Docker." },
    ],
    heroImage: cipherAccueil,
    heroImageCaption: "Page d'accueil",
    secondImage: cipherCoffre,
    secondImageCaption: "Vue d'un coffre-fort",
    competencesSectionIntro: "Véritable projet de fin d'études, cette réalisation est l'aboutissement de mon parcours de BUT :",
    competencesSection: [
      {
        title: 'Développer pour le web et les médias numériques',
        desc: "J'ai poussé le développement web à un niveau avancé en concevant une architecture découplée sécurisée (Symfony pour l'API, Nuxt pour le frontend et PostgreSQL pour les données). J'ai également mis en place l'interfaçage de services d'authentification forte (Double authentification 2FA) et des algorithmes de chiffrement de pointe (AES-256).",
      },
      {
        title: 'Entreprendre dans le secteur du numérique',
        desc: "Ce projet illustre parfaitement ma capacité à construire mon projet professionnel en accord avec mes aspirations (devenir ingénieur DevSecOps). J'ai fait preuve d'une autonomie totale en gérant et conduisant ce projet de bout en bout. De plus, j'ai identifié un besoin réel et non pourvu en entreprise (le partage de clés d'API et secrets entre développeurs) pour concevoir un outil y répondant précisément, ce qui démontre une forte capacité d'initiative et d'entreprenariat.",
      },
    ],
  },
];

const allProjectDetails = [...projectDetails, ...projetsBUTDetails];

const competences = [
  {
    n: 'C4',
    name: 'Développer',
    sub: 'pour le web et les médias numériques',
    desc: "Vue.js + TypeScript sur deux projets d'envergure : la refonte complète de Cantine de saison (SPA, Supabase, SCSS/BEM, architecture scalable) et le Design System Zest (monorepo pnpm, tokens multi-thèmes, composants Vue 3 documentés dans Storybook). JavaScript vanilla pour la carte Leaflet sur Webflow (géolocalisation, filtres, données pilotées par CMS). HTML/CSS/JS responsive en intégration pure pour le Live Passage de Témoin. En formation : Symfony/PHP (Polypdf, Cineverse), API GraphQL découplée, C#/Unity en VR (Nexus) et Nuxt + DevSecOps (Cipher) — 8 projets couvrant frontend, backend, 3D et sécurité.",
    link: '8 projets · du Vue.js au C# en passant par le PHP',
  },
  {
    n: 'C5',
    name: 'Entreprendre',
    sub: 'dans le secteur du numérique',
    desc: "Conduite autonome de projets de A à Z : conception Figma → développement → mise en ligne sans supervision directe sur le Passage de Témoin. Collaboration inter-services avec le pôle Communication pour adapter la charte graphique, et avec les équipes UX/UI pour le Design System. Innovation fonctionnelle : gamification anti-gaspi intégrée dans Cantine de saison, PoC Leaflet sur Webflow là où aucune solution native n'existait. Adoption des pratiques professionnelles : Gitflow, revues de code croisées, réunions d'architecture sur Zest. En formation : modèle freemium + Stripe (Polypdf), pipeline DevSecOps complète from scratch (Cipher).",
    link: 'Conception · livraison · collaboration inter-services',
  },
];

const takeaways = [
  { k: 'Technique',    v: "Architecture monorepo, tokens multi-thèmes et composants Vue 3 documentés dans Storybook — Zest m'a donné une vision concrète de ce qu'est un Design System en production." },
  { k: 'Méthode',      v: "Gitflow, revues de code croisées, réunions d'architecture : des pratiques professionnelles absorbées par immersion, sur quatre projets de stage menés en parallèle." },
  { k: 'Polyvalence',  v: "De la conception Figma à la mise en ligne d'un live pour 12 000 personnes, en passant par la VR et le DevSecOps — huit projets, un spectre technique délibérément large." },
];
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <BaseHead title="Portfolio universitaire — Ewen D'Avanzo" />
  </head>
  <body class="font-sans antialiased" style="overflow-x:hidden;">

    <!-- ambient background -->
    <div class="fixed inset-0 z-0 pointer-events-none">
      <div
        class="absolute inset-0"
        style="background-image:linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px); background-size:64px 64px; -webkit-mask-image:radial-gradient(ellipse 100% 70% at 50% 30%, #000 30%, transparent 80%); mask-image:radial-gradient(ellipse 100% 70% at 50% 30%, #000 30%, transparent 80%);"
      ></div>
      <div
        class="absolute rounded-full"
        style="top:-12%; left:-8%; width:46vw; height:46vw; background:radial-gradient(circle, rgb(var(--acc-rgb) / 0.20), transparent 62%); filter:blur(20px); animation:floaty 13s ease-in-out infinite;"
      ></div>
      <div
        class="absolute rounded-full"
        style="bottom:-18%; right:-10%; width:52vw; height:52vw; background:radial-gradient(circle, rgb(var(--acc-rgb) / 0.13), transparent 64%); filter:blur(24px); animation:floaty2 17s ease-in-out infinite;"
      ></div>
    </div>

    <ScrollProgress />
    <Nav />

    <main class="relative z-[2]">
      <HeroSection heroMeta={heroMeta} />
      <EntrepriseSection stats={entrepriseStats} />
      <MissionsSection missions={missions} />
      <ProjetsBUTSection projets={projetsBUT} />
      <CompetencesSection competences={competences} />
      <BilanSection takeaways={takeaways} />
    </main>

    <footer
      class="relative z-[2] border-t border-white/[0.08]"
      style="padding:36px clamp(20px,7vw,80px); display:flex; flex-wrap:wrap; gap:16px; align-items:center; justify-content:space-between; font-family:'JetBrains Mono',monospace; font-size:12px; color:#6a6a76;"
    >
      <span>© 2026 — Ewen D'Avanzo</span>
      <span>Portfolio universitaire</span>
      <a href="#accueil" class="text-accent no-underline hover:underline">↑ retour en haut</a>
    </footer>

    <ProjectOverlay projects={allProjectDetails} />

    <script>
      // ── SCROLL REVEAL ──────────────────────────────────────────────────────
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (!e.isIntersecting) return;
          e.target.classList.add('visible');
          revealObserver.unobserve(e.target);
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

      // ── SCROLL: PROGRESS + PARALLAX + ACTIVE NAV ──────────────────────────
      const progressBar = document.getElementById('progress-bar');
      const parallaxEls = Array.from(document.querySelectorAll<HTMLElement>('[data-parallax]'));
      const pageSections = Array.from(document.querySelectorAll<HTMLElement>('section[id]'));
      const navLinks = Array.from(document.querySelectorAll<HTMLElement>('[data-nav-id]'));

      function setActiveNav(id: string) {
        navLinks.forEach(a => {
          const isActive = a.dataset.navId === id;
          a.style.color = isActive ? '#ECECF1' : '';
          const underline = a.querySelector<HTMLElement>('.nav-underline');
          if (underline) underline.style.opacity = isActive ? '1' : '0';
        });
      }

      function onScroll() {
        const scrollY = window.scrollY;
        const h = document.documentElement.scrollHeight - window.innerHeight;
        if (progressBar) progressBar.style.transform = `scaleX(${h > 0 ? scrollY / h : 0})`;
        parallaxEls.forEach(el => {
          el.style.transform = `translate3d(0, ${scrollY * parseFloat(el.dataset.parallax ?? '0')}px, 0)`;
        });
        if (scrollY >= 80) {
          const probe = scrollY + window.innerHeight * 0.35;
          let current = pageSections[0]?.id ?? 'accueil';
          pageSections.forEach(s => { if (s.offsetTop <= probe) current = s.id; });
          setActiveNav(current);
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      setTimeout(onScroll, 250);

      // ── PROJECT OVERLAY ────────────────────────────────────────────────────
      // Indices 0-3 = stage, 4-7 = autres (BUT + perso)
      const STAGE_COUNT = 4;
      const OTHER_START = 4;
      const OTHER_COUNT = 4;

      const overlay = document.getElementById('project-overlay')!;
      const overlayCounter = document.getElementById('overlay-counter');
      const overlayNextLabel = document.getElementById('overlay-next-label');
      let currentProjectIndex = 0;

      function openProject(i: number) {
        currentProjectIndex = i;
        let groupIdx: number;
        let counterText: string;
        let hash: string;

        if (i < OTHER_START) {
          groupIdx = i;
          counterText = `projet 0${groupIdx + 1} / 0${STAGE_COUNT}`;
          hash = `#projet-${groupIdx + 1}`;
        } else {
          groupIdx = i - OTHER_START;
          counterText = `projet 0${groupIdx + 1} / 0${OTHER_COUNT}`;
          hash = `#projet-u-${groupIdx + 1}`;
        }

        document.querySelectorAll('[id^="proj-detail-"]').forEach((el, j) => {
          el.classList.toggle('hidden', j !== i);
        });

        if (overlayCounter) overlayCounter.textContent = counterText;

        const article = document.getElementById(`proj-detail-${i}`);
        if (overlayNextLabel && article instanceof HTMLElement) {
          overlayNextLabel.textContent = article.dataset.nextLabel ?? '';
        }

        overlay.classList.remove('hidden');
        overlay.scrollTop = 0;
        document.documentElement.style.overflow = 'hidden';
        document.body.style.overflow = 'hidden';
        document.getElementById('progress-bar-container')?.style.setProperty('display', 'none');

        history.pushState(null, '', hash);
      }

      function closeProject() {
        overlay.classList.add('hidden');
        document.documentElement.style.overflow = '';
        document.body.style.overflow = '';
        document.getElementById('progress-bar-container')?.style.removeProperty('display');
        history.replaceState(null, '', location.pathname + location.search);
      }

      document.addEventListener('click', e => {
        const card = (e.target as HTMLElement).closest<HTMLElement>('[data-project-id]');
        if (card) openProject(Number(card.dataset.projectId));
      });

      document.getElementById('overlay-close')?.addEventListener('click', closeProject);
      document.getElementById('overlay-prev')?.addEventListener('click', closeProject);
      document.getElementById('overlay-next')?.addEventListener('click', () => {
        const i = currentProjectIndex;
        if (i < OTHER_START) {
          openProject((i + 1) % STAGE_COUNT);
        } else {
          openProject(OTHER_START + ((i - OTHER_START + 1) % OTHER_COUNT));
        }
      });

      document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && !overlay.classList.contains('hidden')) closeProject();
      });

      function syncFromHash() {
        const stageM = /^#projet-([1-9])$/.exec(location.hash);
        const otherM = /^#projet-u-([1-9])$/.exec(location.hash);
        if (stageM) openProject(Math.max(0, Math.min(STAGE_COUNT - 1, parseInt(stageM[1], 10) - 1)));
        else if (otherM) openProject(OTHER_START + Math.max(0, Math.min(OTHER_COUNT - 1, parseInt(otherM[1], 10) - 1)));
      }
      syncFromHash();
      window.addEventListener('hashchange', () => {
        if (!/^#projet(-but|-perso)?-\d/.test(location.hash)) closeProject();
      });
      window.addEventListener('popstate', () => {
        if (!/^#projet(-but|-perso)?-\d/.test(location.hash)) {
          overlay.classList.add('hidden');
          document.body.style.overflow = '';
        }
      });

      // ── MOBILE MENU ────────────────────────────────────────────────────────
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      menuToggle?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));
      mobileMenu?.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => mobileMenu?.classList.add('hidden'));
      });

      // ── CUSTOM CURSOR ──────────────────────────────────────────────────────
      if (!window.matchMedia('(hover: none)').matches) {
        document.body.style.cursor = 'none';
        const dot = document.getElementById('cursor-dot')!;
        const ring = document.getElementById('cursor-ring')!;
        let mx = 0, my = 0, rx = 0, ry = 0, hovered = false;

        window.addEventListener('mousemove', e => {
          mx = e.clientX; my = e.clientY;
          dot.style.opacity = '1';
          ring.style.opacity = '1';
        });
        window.addEventListener('mouseover', e => {
          hovered = !!(e.target as HTMLElement).closest?.('a, button, [data-cursor]');
        });

        (function rafLoop() {
          rx += (mx - rx) * 0.18;
          ry += (my - ry) * 0.18;
          dot.style.transform = `translate3d(${mx - 3}px, ${my - 3}px, 0)`;
          ring.style.transform = `translate3d(${rx - 16}px, ${ry - 16}px, 0) scale(${hovered ? 1.7 : 1})`;
          ring.style.borderColor = hovered ? 'rgb(52 211 153)' : 'rgb(52 211 153 / 0.5)';
          ring.style.transition = 'transform 0.15s ease, border-color 0.2s ease';
          requestAnimationFrame(rafLoop);
        })();
      }
    </script>

  </body>
</html>
