---
import Layout from '../layouts/Layout.astro';

const sections = [
  { href: '/entreprise', label: 'Entreprise', num: '01', desc: 'Structure d\'accueil, équipe, contexte' },
  { href: '/missions', label: 'Missions', num: '02', desc: 'Travaux réalisés et technologies mobilisées' },
  { href: '/competences', label: 'Compétences', num: '03', desc: 'Savoir-faire techniques et transversaux' },
  { href: '/bilan', label: 'Bilan', num: '04', desc: 'Retour critique et perspectives' },
];
---

<Layout title="Accueil">
  <!-- Hero -->
  <section class="relative min-h-screen flex flex-col justify-center max-w-5xl mx-auto px-6 pt-14">

    <div class="absolute top-1/4 -left-40 w-[700px] h-[500px] bg-accent/5 rounded-full blur-[160px] pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10">
      <p class="font-mono text-[10px] text-accent/50 tracking-[0.25em] uppercase mb-8 reveal">
        BUT MMI · Développement Web · 2025 — 2026
      </p>

      <h1 class="font-display font-black uppercase leading-[0.85] text-white mb-10 reveal reveal-delay-1 text-[5rem] sm:text-[7rem] md:text-[9.5rem] lg:text-[11.5rem]">
        Rapport<br/>
        <span class="text-accent">de stage</span>
      </h1>

      <div class="flex items-start gap-5 mb-12 reveal reveal-delay-2">
        <div class="w-px h-12 bg-accent/30 mt-0.5 flex-shrink-0"></div>
        <div>
          <p class="text-neutral-300 text-base leading-relaxed">
            Ewen D'Avanzo — Stage chez <span class="text-white font-medium">Api Restauration</span>
          </p>
          <p class="font-mono text-[10px] text-neutral-600 mt-1 tracking-wide uppercase">16 mars → 17 juillet 2025</p>
        </div>
      </div>

      <a
        href="/entreprise"
        class="inline-flex items-center gap-3 px-5 py-2.5 border border-accent/30 hover:border-accent/70 bg-accent/5 hover:bg-accent/10 text-accent-light hover:text-white rounded-lg font-mono text-[10px] uppercase tracking-[0.15em] transition-all duration-300 reveal reveal-delay-3"
      >
        Commencer la lecture
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M2 6h8M6.5 2.5L10 6l-3.5 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 reveal reveal-delay-4">
      <span class="font-mono text-[9px] text-neutral-700 tracking-[0.3em] uppercase">Scroll</span>
      <div class="w-px h-10 bg-gradient-to-b from-neutral-700 to-transparent"></div>
    </div>
  </section>

  <!-- Sommaire -->
  <section class="max-w-5xl mx-auto px-6 pb-28">
    <p class="font-mono text-[10px] text-accent/40 tracking-[0.2em] uppercase mb-8 reveal">Sommaire</p>
    <div class="grid md:grid-cols-2 gap-3">
      {sections.map(({ href, label, num, desc }, i) => (
        <a
          href={href}
          class={`reveal reveal-delay-${i + 1} group relative flex flex-col p-7 rounded-xl border border-white/5 bg-surface hover:bg-white/[0.05] hover:border-accent/30 transition-all duration-300 overflow-hidden`}
        >
          <span aria-hidden="true" class="absolute right-2 top-0 font-display font-extrabold text-[6rem] text-white/[0.03] leading-none select-none pointer-events-none">{num}</span>

          <span class="font-mono text-[10px] text-accent/40 tracking-[0.2em] uppercase mb-5">{num}</span>
          <h2 class="font-display font-extrabold text-2xl tracking-tight text-white mb-2 group-hover:text-accent transition-colors duration-300">{label}</h2>
          <p class="text-sm text-neutral-500 leading-relaxed">{desc}</p>
          <div class="mt-auto pt-6 font-mono text-[10px] text-neutral-700 group-hover:text-accent/60 uppercase tracking-[0.15em] transition-colors duration-300">
            Lire →
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  section {
    position: relative;
  }
</style>
