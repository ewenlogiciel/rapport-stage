---
import Layout from '../layouts/Layout.astro';

const sections = [
  { href: '/entreprise', label: 'Entreprise', num: '01', desc: 'Structure d\'accueil, équipe, contexte' },
  { href: '/missions', label: 'Missions', num: '02', desc: 'Travaux réalisés et technologies mobilisées' },
  { href: '/competences', label: 'Compétences', num: '03', desc: 'Savoir-faire techniques et transversaux' },
  { href: '/bilan', label: 'Bilan', num: '04', desc: 'Retour critique et perspectives' },
];
---

<Layout title="Accueil">
  <!-- Hero -->
  <section class="min-h-screen flex flex-col justify-center max-w-5xl mx-auto px-6 pt-14">

    <!-- Glow background -->
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-accent/10 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10">
      <p class="text-accent-light text-sm font-medium tracking-widest uppercase mb-6 reveal">
        BUT MMI · Développement Web · [Année]
      </p>

      <h1 class="text-6xl md:text-8xl font-black tracking-tighter text-white leading-none mb-6 reveal reveal-delay-1">
        Rapport<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-light to-accent">
          de stage
        </span>
      </h1>

      <p class="text-neutral-400 text-xl max-w-xl leading-relaxed mb-12 reveal reveal-delay-2">
        [Prénom Nom] — Stage chez <span class="text-neutral-200">[Entreprise]</span><br />
        du [date début] au [date fin]
      </p>

      <a
        href="/entreprise"
        class="inline-flex items-center gap-3 px-6 py-3 bg-accent hover:bg-accent-light text-white rounded-lg font-medium text-sm transition-colors reveal reveal-delay-3"
      >
        Commencer la lecture
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-neutral-600 text-xs reveal reveal-delay-4">
      <span>Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-neutral-600 to-transparent"></div>
    </div>
  </section>

  <!-- Index des sections -->
  <section class="max-w-5xl mx-auto px-6 pb-24">
    <div class="grid md:grid-cols-2 gap-4">
      {sections.map(({ href, label, num, desc }) => (
        <a
          href={href}
          class="reveal group relative p-6 rounded-xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.05] hover:border-accent/30 transition-all duration-300"
        >
          <span class="text-xs font-mono text-accent/60 mb-4 block">{num}</span>
          <h2 class="text-xl font-bold text-white mb-2 group-hover:text-accent-light transition-colors">
            {label}
          </h2>
          <p class="text-sm text-neutral-500">{desc}</p>
          <span class="absolute bottom-5 right-5 text-neutral-700 group-hover:text-accent transition-colors text-lg">→</span>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  section {
    position: relative;
  }
</style>
