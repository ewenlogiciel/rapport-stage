---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <BaseHead title="Rapport de Stage — Ewen Davanzo" />
  </head>
  <body class="font-sans antialiased overflow-x-hidden">

    <!-- ambient background -->
    <div class="fixed inset-0 z-0 pointer-events-none">
      <div
        class="absolute inset-0"
        style="background-image:linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px); background-size:64px 64px; -webkit-mask-image:radial-gradient(ellipse 100% 70% at 50% 30%, #000 30%, transparent 80%); mask-image:radial-gradient(ellipse 100% 70% at 50% 30%, #000 30%, transparent 80%);"
      ></div>
      <div
        class="absolute rounded-full"
        style="top:-12%; left:-8%; width:46vw; height:46vw; background:radial-gradient(circle, rgb(var(--acc-rgb) / 0.20), transparent 62%); filter:blur(20px); animation:floaty 13s ease-in-out infinite;"
      ></div>
      <div
        class="absolute rounded-full"
        style="bottom:-18%; right:-10%; width:52vw; height:52vw; background:radial-gradient(circle, rgb(var(--acc-rgb) / 0.13), transparent 64%); filter:blur(24px); animation:floaty2 17s ease-in-out infinite;"
      ></div>
    </div>

    <ScrollProgress />
    <Nav />

    <main class="relative z-[2]">
      <HeroSection heroMeta={heroMeta} />
      <EntrepriseSection stats={entrepriseStats} />
      <MissionsSection missions={missions} />
      <CompetencesSection competences={competences} />
      <BilanSection takeaways={takeaways} />
    </main>

    <footer
      class="relative z-[2] border-t border-white/[0.08]"
      style="padding:36px clamp(20px,7vw,80px); display:flex; flex-wrap:wrap; gap:16px; align-items:center; justify-content:space-between; font-family:'JetBrains Mono',monospace; font-size:12px; color:#6a6a76;"
    >
      <span>© 2025 — Ewen Davanzo · BUT MMI</span>
      <span>Rapport de stage · Api Restauration</span>
      <a href="#accueil" class="text-accent no-underline hover:underline">↑ retour en haut</a>
    </footer>

    <ProjectOverlay projects={projectDetails} />

    <script>
      // ── SCROLL REVEAL ──────────────────────────────────────────────────────
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (!e.isIntersecting) return;
          e.target.classList.add('visible');
          revealObserver.unobserve(e.target);
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

      // ── TERMINAL LINES ─────────────────────────────────────────────────────
      const termLines = Array.from(document.querySelectorAll<HTMLElement>('[data-termline]'));
      termLines.forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateX(-8px)';
        el.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
      });
      termLines.forEach((el, i) => {
        setTimeout(() => { el.style.opacity = '1'; el.style.transform = 'none'; }, 350 + i * 180);
      });
      setTimeout(() => {
        termLines.forEach(el => { el.style.opacity = '1'; el.style.transform = 'none'; });
      }, 3500);

      // ── SCROLL: PROGRESS + PARALLAX + ACTIVE NAV ──────────────────────────
      const progressBar = document.getElementById('progress-bar');
      const parallaxEls = Array.from(document.querySelectorAll<HTMLElement>('[data-parallax]'));
      const pageSections = Array.from(document.querySelectorAll<HTMLElement>('section[id]'));
      const navLinks = Array.from(document.querySelectorAll<HTMLElement>('[data-nav-id]'));

      function setActiveNav(id: string) {
        navLinks.forEach(a => {
          const isActive = a.dataset.navId === id;
          a.style.color = isActive ? '#ECECF1' : '';
          const underline = a.querySelector<HTMLElement>('.nav-underline');
          if (underline) underline.style.opacity = isActive ? '1' : '0';
        });
      }

      function onScroll() {
        const scrollY = window.scrollY;
        const h = document.documentElement.scrollHeight - window.innerHeight;
        if (progressBar) progressBar.style.transform = `scaleX(${h > 0 ? scrollY / h : 0})`;
        parallaxEls.forEach(el => {
          el.style.transform = `translate3d(0, ${scrollY * parseFloat(el.dataset.parallax ?? '0')}px, 0)`;
        });
        if (scrollY >= 80) {
          const probe = scrollY + window.innerHeight * 0.35;
          let current = pageSections[0]?.id ?? 'accueil';
          pageSections.forEach(s => { if (s.offsetTop <= probe) current = s.id; });
          setActiveNav(current);
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      setTimeout(onScroll, 250);

      // ── PROJECT OVERLAY ────────────────────────────────────────────────────
      const overlay = document.getElementById('project-overlay')!;
      const overlayCounter = document.getElementById('overlay-counter');
      const overlayNextLabel = document.getElementById('overlay-next-label');
      let currentProjectIndex = 0;

      function openProject(i: number) {
        currentProjectIndex = i;
        document.querySelectorAll('[id^="proj-detail-"]').forEach((el, j) => {
          el.classList.toggle('hidden', j !== i);
        });
        if (overlayCounter) overlayCounter.textContent = `projet 0${i + 1} / 04`;
        const article = document.getElementById(`proj-detail-${i}`);
        if (overlayNextLabel && article instanceof HTMLElement) {
          overlayNextLabel.textContent = article.dataset.nextLabel ?? '';
        }
        overlay.classList.remove('hidden');
        overlay.scrollTop = 0;
        document.body.style.overflow = 'hidden';
        history.pushState(null, '', `#projet-${i + 1}`);
      }

      function closeProject() {
        overlay.classList.add('hidden');
        document.body.style.overflow = '';
        history.replaceState(null, '', location.pathname + location.search);
      }

      document.addEventListener('click', e => {
        const card = (e.target as HTMLElement).closest<HTMLElement>('[data-project-id]');
        if (card) openProject(Number(card.dataset.projectId));
      });

      document.getElementById('overlay-close')?.addEventListener('click', closeProject);
      document.getElementById('overlay-prev')?.addEventListener('click', closeProject);
      document.getElementById('overlay-next')?.addEventListener('click', () => {
        openProject((currentProjectIndex + 1) % 4);
      });

      document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && !overlay.classList.contains('hidden')) closeProject();
      });

      function syncFromHash() {
        const m = /projet-(\d)/.exec(location.hash);
        if (m) openProject(Math.max(0, Math.min(3, parseInt(m[1], 10) - 1)));
      }
      syncFromHash();
      window.addEventListener('hashchange', () => {
        if (!/projet-\d/.test(location.hash)) closeProject();
      });
      window.addEventListener('popstate', () => {
        if (!/projet-\d/.test(location.hash)) {
          overlay.classList.add('hidden');
          document.body.style.overflow = '';
        }
      });

      // ── MOBILE MENU ────────────────────────────────────────────────────────
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      menuToggle?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));
      mobileMenu?.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => mobileMenu?.classList.add('hidden'));
      });

      // ── CUSTOM CURSOR ──────────────────────────────────────────────────────
      if (!window.matchMedia('(hover: none)').matches) {
        document.body.style.cursor = 'none';
        const dot = document.getElementById('cursor-dot')!;
        const ring = document.getElementById('cursor-ring')!;
        let mx = 0, my = 0, rx = 0, ry = 0, hovered = false;

        window.addEventListener('mousemove', e => {
          mx = e.clientX; my = e.clientY;
          dot.style.opacity = '1';
          ring.style.opacity = '1';
        });
        window.addEventListener('mouseover', e => {
          hovered = !!(e.target as HTMLElement).closest?.('a, button, [data-cursor]');
        });

        (function rafLoop() {
          rx += (mx - rx) * 0.18;
          ry += (my - ry) * 0.18;
          dot.style.transform = `translate3d(${mx - 3}px, ${my - 3}px, 0)`;
          ring.style.transform = `translate3d(${rx - 16}px, ${ry - 16}px, 0) scale(${hovered ? 1.7 : 1})`;
          ring.style.borderColor = hovered ? 'rgb(52 211 153)' : 'rgb(52 211 153 / 0.5)';
          ring.style.transition = 'transform 0.15s ease, border-color 0.2s ease';
          requestAnimationFrame(rafLoop);
        })();
      }
    </script>

  </body>
</html>
