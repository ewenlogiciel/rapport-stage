const allProjectDetails = [...projectDetails, ...projetsBUTDetails];

const competences = [
  {
    n: 'C4', name: 'Développer', sub: 'pour le web et les médias',
    desc: 'Intégration front (Vue, TypeScript), code custom Leaflet et composants documentés dans Storybook.',
    link: 'Design system & carte Leaflet',
