---
import BaseHead from '../layouts/BaseHead.astro';
import Nav from '../components/Nav.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import HeroSection from '../components/HeroSection.astro';
import EntrepriseSection from '../components/EntrepriseSection.astro';
import MissionsSection from '../components/MissionsSection.astro';
import ProjetsBUTSection from '../components/ProjetsBUTSection.astro';
import CompetencesSection from '../components/CompetencesSection.astro';
import BilanSection from '../components/BilanSection.astro';
import ProjectOverlay from '../components/ProjectOverlay.astro';
import polypdfAccueil from '../assets/pojets-universitaires/polypdf/polypdf-accauil.png';
import polypdfOutils from '../assets/pojets-universitaires/polypdf/polypdf-outils.png';
import civerseAccueil from '../assets/pojets-universitaires/cineverse/cineverse-accueil.png';
