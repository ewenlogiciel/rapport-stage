---
import Layout from '../layouts/Layout.astro';

const points = [
  { type: 'positif', label: '[À REMPLIR]' },
  { type: 'positif', label: '[À REMPLIR]' },
  { type: 'améliorer', label: '[À REMPLIR]' },
];
---

<Layout title="Bilan">
  <main class="max-w-5xl mx-auto px-6 pt-28 pb-24">

    <div class="mb-16 reveal">
      <span class="text-xs font-mono text-accent/60 block mb-3">04 / Bilan</span>
      <h1 class="text-5xl md:text-6xl font-black tracking-tighter text-white mb-4">
        Bilan
      </h1>
      <p class="text-neutral-500 text-lg">Retour critique sur l'expérience</p>
    </div>

    <div class="grid md:grid-cols-3 gap-12 mb-16">
      <div class="md:col-span-2 space-y-12">
        <section class="reveal">
          <h2 class="text-xs font-mono text-accent-light tracking-widest uppercase mb-4">Ce que j'ai appris</h2>
          <p class="text-neutral-300 leading-relaxed">
            [À REMPLIR — apprentissages techniques, humains, organisationnels, ce qui a changé ta vision du métier]
          </p>
        </section>

        <section class="reveal reveal-delay-1">
          <h2 class="text-xs font-mono text-accent-light tracking-widest uppercase mb-4">Et après ?</h2>
          <p class="text-neutral-300 leading-relaxed">
            [À REMPLIR — suite du parcours, master/emploi envisagé, projet perso, ce que ce stage t'a apporté pour la suite]
          </p>
        </section>
      </div>

      <!-- Points forts / à améliorer -->
      <aside class="reveal reveal-delay-1">
        <div class="sticky top-20 space-y-3">
          <h3 class="text-xs font-mono text-neutral-600 mb-4 uppercase tracking-widest">Points clés</h3>
          {points.map(({ type, label }) => (
            <div class={`flex items-start gap-3 p-3 rounded-lg border text-sm ${
              type === 'positif'
                ? 'border-accent/20 bg-accent/5 text-accent-light'
                : 'border-amber-500/20 bg-amber-500/5 text-amber-300'
            }`}>
              <span class="mt-0.5">{type === 'positif' ? '↑' : '→'}</span>
              <span>{label}</span>
            </div>
          ))}
        </div>
      </aside>
    </div>

    <!-- Citation finale -->
    <div class="reveal py-12 border-y border-white/5 text-center">
      <p class="text-2xl md:text-3xl font-bold text-white/20 italic max-w-2xl mx-auto">
        « [Une phrase qui résume ton expérience de stage] »
      </p>
    </div>

    <div class="flex justify-between mt-8 reveal">
      <a href="/competences" class="text-accent-light hover:text-white text-sm transition-colors">← Compétences</a>
      <a href="/" class="text-accent-light hover:text-white text-sm transition-colors">↑ Accueil</a>
    </div>
  </main>
</Layout>
