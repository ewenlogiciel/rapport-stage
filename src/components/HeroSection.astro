---
interface HeroMeta {
  k: string;
  v: string;
}
interface Props {
  heroMeta: HeroMeta[];
}
const { heroMeta } = Astro.props;
---

<section
  id="accueil"
  class="relative z-[2] min-h-screen flex flex-col justify-center scroll-mt-[88px]"
  style="padding:130px clamp(20px,7vw,80px) 56px;"
>
  <div class="font-mono text-[13px] tracking-[0.18em] text-accent mb-[34px] reveal">
    // BUT MMI · STAGE 2025 · API RESTAURATION
  </div>

  <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(360px,1fr)); gap:clamp(28px,4vw,64px); align-items:center;">
    <div>
      <h1
        class="m-0 font-semibold leading-[0.96] tracking-[-0.03em] reveal"
        style="font-size:clamp(44px,6.5vw,104px);"
      >
        Rapport<br />de stage<span class="text-accent">.</span>
      </h1>
      <p
        class="m-0 mt-7 text-[#a3a3ad] leading-[1.55] reveal reveal-delay-1"
        style="max-width:30ch; font-size:clamp(16px,1.4vw,20px);"
      >
        Dix-huit semaines au pôle digital d'Api Restauration — entre refonte d'interfaces, intégration front et design system.
      </p>
    </div>

    <div
      class="border border-white/[0.09] rounded-xl overflow-hidden reveal reveal-delay-2"
      style="background:rgba(13,13,18,0.82); box-shadow:0 30px 80px -30px rgba(0,0,0,0.8);"
    >
      <div class="flex items-center gap-2 border-b border-white/[0.07] bg-white/[0.02]" style="padding:13px 16px;">
        <span class="w-[11px] h-[11px] rounded-full bg-[#ff5f57]"></span>
        <span class="w-[11px] h-[11px] rounded-full bg-[#febc2e]"></span>
        <span class="w-[11px] h-[11px] rounded-full bg-[#28c840]"></span>
        <span class="ml-2 font-mono text-[11px] text-[#6c6c78]">stage — bash</span>
      </div>
      <div class="font-mono text-[13.5px] leading-[1.95]" style="padding:22px 22px 26px;">
        <div data-termline><span class="text-accent">$</span> <span class="text-[#cfcfd6]">whoami</span></div>
        <div data-termline class="text-[#8a8a96]">&gt; Ewen Davanzo — étudiant BUT MMI</div>
        <div data-termline class="h-2"></div>
        <div data-termline><span class="text-accent">$</span> <span class="text-[#cfcfd6]">cat stage.json</span></div>
        <div data-termline class="text-[#8a8a96]">&gt; &#123;</div>
        <div data-termline class="text-[#8a8a96] pl-5">"entreprise": <span class="text-[#9be59b]">"Api Restauration"</span>,</div>
        <div data-termline class="text-[#8a8a96] pl-5">"durée": <span class="text-[#9be59b]">"18 semaines"</span>,</div>
        <div data-termline class="text-[#8a8a96] pl-5">"pôle": <span class="text-[#9be59b]">"digital / web"</span>,</div>
        <div data-termline class="text-[#8a8a96] pl-5">"projets": <span class="text-[#e0a3ff]">4</span></div>
        <div data-termline class="text-[#8a8a96]">&gt; &#125;</div>
        <div data-termline class="h-2"></div>
        <div data-termline>
          <span class="text-accent">$</span>
          <span class="text-[#cfcfd6]"> ./lancer --immersif</span>
          <span
            class="inline-block w-[9px] h-[17px] bg-accent ml-1.5 align-[-3px]"
            style="animation:blink 1.1s step-end infinite;"
          ></span>
        </div>
      </div>
    </div>
  </div>

  <div
    class="border-t border-white/[0.08] pt-[26px] reveal reveal-delay-2"
    style="margin-top:clamp(40px,7vh,90px); display:grid; grid-template-columns:repeat(auto-fit, minmax(150px,1fr)); gap:24px;"
  >
    {heroMeta.map((m) => (
      <div>
        <div class="font-mono text-[11px] tracking-[0.1em] uppercase text-[#6a6a76]">{m.k}</div>
        <div class="mt-[7px] text-[18px] text-white">{m.v}</div>
      </div>
    ))}
  </div>
</section>
