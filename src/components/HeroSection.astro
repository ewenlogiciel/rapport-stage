---
interface HeroMeta {
  k: string;
  v: string;
}
interface Props {
  heroMeta: HeroMeta[];
}
const { heroMeta } = Astro.props;
---

<section
  id="accueil"
  class="relative z-[2] min-h-screen flex flex-col justify-center scroll-mt-[88px]"
  style="padding:130px clamp(20px,7vw,80px) 56px;"
>
  <div class="font-mono text-[13px] tracking-[0.18em] text-accent mb-[34px] reveal">
    // BUT MMI SPECIALITE DEVELOPPEMENT WEB ET DISPOSITIFS INTERACTIFS· 2025/2026 · API RESTAURATION
  </div>

  <h1
    class="m-0 font-semibold leading-[0.94] tracking-[-0.03em] reveal reveal-delay-1"
    style="font-size:clamp(56px,9vw,140px);"
  >
    Portfolio<br /><span class="text-accent">universitaire</span>
  </h1>

  <p
    class="m-0 mt-8 text-[#a3a3ad] leading-[1.55] reveal reveal-delay-2"
    style="max-width:36ch; font-size:clamp(16px,1.4vw,20px);"
  >
    Stage chez Api Restauration et cursus BUT MMI — design system, refonte d'interfaces, full-stack, réalité virtuelle et DevSecOps.
  </p>

  <div
    class="border-t border-white/[0.08] pt-[26px] reveal reveal-delay-3"
    style="margin-top:clamp(56px,9vh,100px); display:grid; grid-template-columns:repeat(auto-fit, minmax(150px,1fr)); gap:24px;"
  >
    {heroMeta.map((m) => (
      <div>
        <div class="font-mono text-[11px] tracking-[0.1em] uppercase text-[#6a6a76]">{m.k}</div>
        <div class="mt-[7px] text-[18px] text-white">{m.v}</div>
      </div>
    ))}
  </div>
</section>
