---
const navItems = [
  { href: '#accueil',     label: 'Accueil',      n: '00' },
  { href: '#entreprise',  label: 'Entreprise',    n: '01' },
  { href: '#missions',    label: 'Missions',      n: '02' },
  { href: '#competences', label: 'Compétences',   n: '03' },
  { href: '#bilan',       label: 'Bilan',         n: '04' },
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-[150] flex items-center justify-between backdrop-blur-[14px] border-b border-white/[0.06]"
  style="padding:18px clamp(20px,7vw,80px); background:linear-gradient(180deg, rgba(7,7,10,0.85), rgba(7,7,10,0.4));"
>
  <a href="#accueil" class="font-mono text-[13px] tracking-[0.02em] text-white no-underline flex items-center gap-2">
    <span class="w-2 h-2 rounded-full bg-accent" style="box-shadow:0 0 10px var(--color-accent);"></span>
    <span class="text-[#7a7a86]">~/</span>rapport-de-stage
  </a>

  <div class="hidden md:flex items-center" style="gap:clamp(14px,2vw,34px);">
    {navItems.map((item) => (
      <a
        href={item.href}
        data-nav-id={item.href.slice(1)}
        class="nav-link relative font-mono text-[12px] tracking-[0.04em] uppercase no-underline text-[#9a9aa6] py-1.5 flex items-center gap-[7px] transition-colors duration-200"
      >
        <span class="text-[10px] text-[#55555f]">{item.n}</span>
        {item.label}
        <span class="nav-underline absolute left-0 right-0 -bottom-0.5 h-[1.5px] bg-accent opacity-0 transition-opacity duration-200" style="box-shadow:0 0 8px var(--color-accent);"></span>
      </a>
    ))}
  </div>

  <button id="menu-toggle" class="md:hidden text-[#9a9aa6] hover:text-white transition-colors" aria-label="Menu">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
      <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>
</nav>

<div
  id="mobile-menu"
  class="hidden fixed top-[61px] left-0 right-0 z-[140] border-b border-white/5 backdrop-blur-md md:hidden"
  style="background:rgba(7,7,10,0.95);"
>
  <ul class="px-6 py-4 space-y-3 list-none m-0">
    {navItems.map((item) => (
      <li>
        <a
          href={item.href}
          class="block font-mono text-[11px] uppercase tracking-[0.15em] py-1.5 text-[#9a9aa6] hover:text-white transition-colors no-underline"
        >
          <span class="text-accent mr-2">{item.n}</span>{item.label}
        </a>
      </li>
    ))}
  </ul>
</div>
